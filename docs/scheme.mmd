---
config:
  layout: dagre
  flowchart:
    htmlLabels: true
---
flowchart TB
    User(["<span style='font-size:16px;font-weight:bold;'>User</span><br><span style='font-size:13px;color:#01579b;'>Person interacting with system</span>"])

    User -- speech --> Robot

    subgraph RobotSide["Reachy Mini (robot)"]
        Robot@{ label: "<span style='font-size:16px;font-weight:bold;'>reachy_mini</span><br><span style='font-size:13px;color:#c62828;'>Hardware + mic + camera</span>" }
        UI@{ label: "<span style='font-size:16px;font-weight:bold;'>UI Layer</span><br><span style='font-size:13px;color:#0277bd;'>Gradio + Settings web UI</span>" }
        Orchestrator@{ label: "<span style='font-size:17px;font-weight:bold;'>OpenaiRealtimeHandler</span><br><span style='font-size:13px;color:#7b1fa2;'>Wake gating + Realtime session</span>" }
        WakeClient@{ label: "<span style='font-size:16px;font-weight:bold;'>RemoteWakeClient</span><br><span style='font-size:13px;color:#0277bd;'>Streams PCM while asleep</span>" }
        Camera@{ label: "<span style='font-size:16px;font-weight:bold;'>Camera Worker</span><br><span style='font-size:13px;color:#f57f17;'>Frame buffer + head tracking</span>" }
        Motion@{ label: "<span style='font-size:16px;font-weight:bold;'>Motion Control</span><br><span style='font-size:13px;color:#f57f17;'>Audio sync + tracking</span>" }
    end

    subgraph MacSide["Mac (wake daemon host)"]
        WakeDaemon@{ label: "<span style='font-size:16px;font-weight:bold;'>bobe-wake-daemon</span><br><span style='font-size:13px;color:#0277bd;'>WhisperWakeEngine + WebSocket</span>" }
    end

    subgraph Cloud["Cloud APIs"]
        OpenAI@{ label: "<span style='font-size:17px;font-weight:bold;'>OpenAI Realtime</span><br><span style='font-size:13px;color:#7b1fa2;'>Speech I/O + tool calls + vision</span>" }
        Claude@{ label: "<span style='font-size:16px;font-weight:bold;'>Anthropic Claude</span><br><span style='font-size:13px;color:#7b1fa2;'>Answers via ask_claude tool</span>" }
    end

    Profiles@{ label: "<span style='font-size:16px;font-weight:bold;'>Profile</span><br><span style='font-size:12px;color:#6a1b9a;'>instructions.txt + tools.txt<br/>+ profile-local Python tools</span>" }
    Handlers@{ label: "<span style='font-size:16px;font-weight:bold;'>Tool Layer</span><br><span style='font-size:12px;color:#f9a825;'>Built-in + profile + external tools</span>" }
    Vision@{ label: "<span style='font-size:16px;font-weight:bold;'>LocalVision (optional)</span><br><span style='font-size:13px;color:#7b1fa2;'>SmolVLM via --local-vision</span>" }

    Robot -- mic frames --> Orchestrator
    UI --> Orchestrator
    Orchestrator -- asleep PCM --> WakeClient
    WakeClient -- WebSocket --> WakeDaemon
    WakeDaemon -- wake event --> WakeClient
    WakeClient -- wake signal --> Orchestrator

    Orchestrator -- awake audio --> OpenAI
    OpenAI -- audio + tool calls --> Orchestrator
    Orchestrator -- motion requests --> Motion
    Motion -- commands --> Robot

    OpenAI -- ask_claude tool --> Handlers
    Handlers -- Claude API --> Claude
    Claude -- answer --> Handlers
    Handlers -- tool results --> OpenAI

    Profiles -- defines enabled tools --> Handlers
    Handlers -- camera / tracking --> Camera
    Robot -- camera frames --> Camera
    Camera -- head tracking --> Motion

    Camera -. optional frames .-> Vision
    Vision -. description .-> Handlers
    Handlers -. image for analysis .-> OpenAI

    User:::userStyle
    UI:::uiStyle
    OpenAI:::aiStyle
    Claude:::aiStyle
    Orchestrator:::aiStyle
    Motion:::coreStyle
    Profiles:::toolStyle
    Handlers:::toolStyle
    Camera:::coreStyle
    Vision:::aiStyle
    Robot:::hardwareStyle
    WakeClient:::uiStyle
    WakeDaemon:::uiStyle

    classDef userStyle fill:#e1f5fe,stroke:#01579b,stroke-width:3px
    classDef uiStyle fill:#b3e5fc,stroke:#0277bd,stroke-width:2px
    classDef aiStyle fill:#e1bee7,stroke:#7b1fa2,stroke-width:3px
    classDef coreStyle fill:#fff9c4,stroke:#f57f17,stroke-width:2px
    classDef hardwareStyle fill:#ef9a9a,stroke:#c62828,stroke-width:3px
    classDef toolStyle fill:#fffde7,stroke:#f9a825,stroke-width:1px
