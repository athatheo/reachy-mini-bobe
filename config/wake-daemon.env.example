# Mac wake daemon environment (copy to config/wake-daemon.env)
WAKE_DAEMON_HOST=0.0.0.0
WAKE_DAEMON_PORT=8765
BOBE_WAKE_TOKEN=change-me-to-a-long-random-string
BOBE_WAKE_PHRASE="hey jarvis"
WHISPER_MODEL=distil-small.en
WHISPER_DEVICE=auto
WHISPER_COMPUTE_TYPE=int8
# Mild Whisper bias (wake name only). Hotwords stay off — they rewrite "service" as "Jarvis".
# WHISPER_INITIAL_PROMPT="Jarvis."
# WHISPER_HOTWORDS="Jarvis"
VAD_SPEECH_RMS=450
VAD_END_SILENCE_MS=200
VAD_MIN_SPEECH_MS=250
WAKE_REFRACTORY_S=2.5

# Optional Claude Code voice launch and managed-session endpoints.
# Keep disabled until BOBE_CLAUDE_CODE_LAUNCH_TOKEN is set on both Mac and robot.
BOBE_CLAUDE_CODE_LAUNCH_ENABLED=0
BOBE_CLAUDE_CODE_LAUNCH_TOKEN=
BOBE_CLAUDE_CODE_WORKDIR=~/repos/bobe-claude-code-workspace
BOBE_CLAUDE_CODE_BIN=claude
BOBE_CLAUDE_CODE_LAUNCH_COOLDOWN_S=30
BOBE_CLAUDE_CODE_COMMAND_TIMEOUT_S=300
BOBE_CLAUDE_CODE_OUTPUT_LIMIT_CHARS=6000
# Claude CLI permission mode for managed commands: default, plan, acceptEdits, auto, dontAsk, bypassPermissions.
BOBE_CLAUDE_CODE_PERMISSION_MODE=default
